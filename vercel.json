{
  "version": 3,
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/server.js" },
    { "src": "/health", "dest": "/api/server.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
